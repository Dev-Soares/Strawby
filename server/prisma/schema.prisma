generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  plan         Plan?
  meals        Meal[]
  privateFoods PrivateFood[]
}

model Plan {
  id        String   @id @default(uuid())
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Food {
  id            String         @id @default(uuid())
  name          String
  nameOriginal  String?
  source        FoodSource
  sourceId      String?
  sourceUrl     String?
  category      String?
  priority      Int            @default(0)
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  fiber         Float?
  sodium        Float?
  servingSize   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  foodItems     FoodItem[]

  @@unique([source, sourceId])
  @@index([priority(sort: Desc), name])
}

model PrivateFood {
  id          String     @id @default(uuid())
  name        String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sodium      Float?
  servingSize String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItems   FoodItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

enum FoodSource {
  TACO
  USDA_FOUNDATION
  USDA_SR_LEGACY
  CNF
  LIVS
  OFF
  MANUAL
}

enum MealKind {
  DAILY
  PLAN
}

model Meal {
  id        String     @id @default(uuid())
  name      String
  kind      MealKind   @default(DAILY)
  mealType  String?
  time      String?
  date      DateTime   @default(now())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     FoodItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, kind, date])
}

model FoodItem {
  id            String       @id @default(uuid())
  quantity      Float
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  mealId        String
  foodId        String?
  privateFoodId String?
  meal          Meal         @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food          Food?        @relation(fields: [foodId], references: [id])
  privateFood   PrivateFood? @relation(fields: [privateFoodId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([mealId])
}
